OPENAI_BASE_URL=https://inference.de-txl.ionos.com
OPENAI_API_KEY=YOUR_TOKEN_HERE
# TBD: Find correct IONOS embedding model name
OPENAI_EMBED_MODEL=text-embedding-ada-002

# Ollama (API on bridge; use gateway IP to reach host)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=all-minilm

# Retrieval
DEFAULT_TOP_K=5
MAX_TOP_K=50
DEFAULT_MODEL_FILTER=


IONOS_RAG_BASE_URL=https://inference.de-txl.ionos.com

# Optional: full, model-specific chat endpoint provided by IONOS console.
# If set, the client will POST directly to this URL instead of composing
# "{IONOS_RAG_BASE_URL}/v1/chat/completions". Example:
IONOS_RAG_CHAT_ENDPOINT=https://openai.inference.de-txl.ionos.com/v1/chat/completions


# 2. API Key (your existing token)
IONOS_RAG_API_KEY=YOUR_TOKEN_HERE

# 3. Model ID (common IONOS LLM models)
IONOS_RAG_MODEL_ID=meta-llama/Llama-3.3-70B-Instruct

# 4. Collection/Index ID (your existing collection)
IONOS_RAG_INDEX_ID=908cb8ea-58e3-4d87-a41b-05fa91a818d8

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Required for calling /api/* endpoints (external clients). The /chat/ UI does NOT need this.
RAG_API_KEY=change-me

# Postgres
DATABASE_URL=postgres://rag:rag@localhost:5432/rag